# ============================================================
# AI Code Security Scanner — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=scanner
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=scanner_db
DATABASE_URL=postgresql+asyncpg://scanner:change_me_in_production@localhost:5432/scanner_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Groq ────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=grok-api-key
# Recommended models (all free-tier eligible):
#   llama-3.3-70b-versatile  ← best quality (default)
#   llama-3.1-8b-instant     ← fastest
#   mixtral-8x7b-32768       ← large context window
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# ── GitHub App ───────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps/new
# Required permissions: Pull requests (read/write), Contents (read)
# Required events: pull_request
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_NAME=ai-code-security-scanner
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Auth / Security ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App Config ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_FREE_RPM=60
RATE_LIMIT_PRO_RPM=300

# ── Scan Limits ──────────────────────────────────────────────
MAX_CODE_SIZE_KB=100
MAX_CODE_LINES=5000
SCAN_CACHE_TTL_SECONDS=86400

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
